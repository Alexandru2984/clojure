[Unit]
Description=Clojure EventPulse
After=network.target

[Service]
Type=simple
User=micu
Group=micu
WorkingDirectory=/home/micu/clojure
EnvironmentFile=/home/micu/clojure/.env
ExecStart=/usr/bin/java -jar /home/micu/clojure/target/eventpulse-standalone.jar
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
PrivateDevices=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/home/micu/clojure/data
ReadOnlyPaths=/home/micu/clojure
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictSUIDSGID=true
LockPersonality=true
CapabilityBoundingSet=
SystemCallArchitectures=native
UMask=0077

[Install]
WantedBy=multi-user.target
